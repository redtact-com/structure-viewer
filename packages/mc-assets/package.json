{
  "name": "@redtact/mc-assets",
  "version": "0.2.0",
  "description": "Self-hosted Minecraft asset pipeline for deepslate viewers: blockstates/models/texture fetching, deepslate Resources building, and an asset download CLI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./urls": {
      "import": {
        "types": "./dist/urls.d.ts",
        "default": "./dist/urls.js"
      },
      "require": {
        "types": "./dist/urls.d.cts",
        "default": "./dist/urls.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20.19"
  },
  "bin": {
    "fetch-mc-assets": "./bin/fetch-mc-assets.mjs"
  },
  "typesVersions": {
    "*": {
      "urls": [
        "./dist/urls.d.ts"
      ]
    }
  },
  "files": [
    "dist/",
    "bin/",
    "urls/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "keywords": [
    "minecraft",
    "deepslate",
    "assets",
    "textures",
    "blockstates",
    "resources"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "deepslate": "^0.25.1"
  },
  "dependencies": {
    "@redtact/deepslate-extras": "workspace:^"
  },
  "devDependencies": {
    "deepslate": "^0.25.1",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "license": "Apache-2.0",
  "author": "redtact",
  "repository": {
    "type": "git",
    "url": "https://github.com/redtact-com/structure-viewer.git",
    "directory": "packages/mc-assets"
  },
  "homepage": "https://github.com/redtact-com/structure-viewer#readme"
}
