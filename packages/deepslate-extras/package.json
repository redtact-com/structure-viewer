{
  "name": "@redtact/deepslate-extras",
  "version": "0.2.0",
  "description": "Extras for deepslate structure viewers: bit-identical performance patches, fade rendering, structure splitting, raycasting, and a dirty-flag render loop.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "bench": "node tools/bench-viewer.mjs"
  },
  "keywords": [
    "minecraft",
    "deepslate",
    "structure",
    "viewer",
    "webgl",
    "renderer"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "deepslate": "^0.25.1"
  },
  "dependencies": {
    "gl-matrix": "^3.4.4"
  },
  "devDependencies": {
    "deepslate": "^0.25.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "license": "Apache-2.0",
  "author": "redtact",
  "repository": {
    "type": "git",
    "url": "https://github.com/redtact-com/structure-viewer.git",
    "directory": "packages/deepslate-extras"
  },
  "homepage": "https://github.com/redtact-com/structure-viewer#readme"
}
